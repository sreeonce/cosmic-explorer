---
const { title = "Cosmic Explorer" } = Astro.props;
---

<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>{title}</title>

    <!-- Fonts -->
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Libre+Bodoni&family=Libre+Caslon+Display&display=swap" rel="stylesheet">
  </head>

  <body>
    <slot />
    <!-- FOOTER BOTTOM -->
    <section class="footer-small">
      <h2>Ready to explore beyond Earth? Start your journey now!</h2>
      <footer>© 2026 Cosmic Explorer. Built with Astro.</footer>
    </section>
  </body>
</html>