---
import MainLayout from "../layouts/MainLayout.astro";
import WeightCalculator from "../components/WeightCalculator.jsx";
import "../styles/global.css";
---

<MainLayout title="Planet Weight Calculator">
  <section class="header" style="
  background-image: url('/Figma/home-footer.png');
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 20px 40px;
">
  <img src="/Figma/logo.png" style="
    height: 50px;
    width: auto;
  ">

  <a href="/">
    <img src="/Figma/back-icon.png" style="
      height: 60px;
      width: auto;
      cursor: pointer;
    ">
  </a>
</section>

  <section class="calculator-page">
    <WeightCalculator client:load />
  </section>

</MainLayout>